# Copy to .env and edit — loaded by config.py at startup
# All values have sensible defaults; only override what you need.

# Serial port for ESP32 connection
# SERIAL_PORT=/dev/ttyUSB0
# SERIAL_BAUD=115200

# Camera resolution and framerate
# CAMERA_WIDTH=1280
# CAMERA_HEIGHT=720
# CAMERA_FPS=30

# MJPEG stream quality (1-95)
# MJPEG_QUALITY=75

# YOLOv8 detection confidence threshold
# YOLO_CONFIDENCE=0.45

# Face recognition tolerance (lower = stricter, 0.4-0.6 typical)
# FACE_RECOGNITION_TOLERANCE=0.5

# Claude API key (optional — only needed for NL command features)
# ANTHROPIC_API_KEY=sk-ant-...
