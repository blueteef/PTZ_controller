# Copy to .env and edit — loaded by config.py at startup.
# All values have sensible defaults; only override what you need.
# cp .env.example .env

# ---------------------------------------------------------------------------
# Serial
# ---------------------------------------------------------------------------
# SERIAL_PORT=/dev/serial0       # GPIO UART (hardware); use /dev/ttyUSB0 for USB
# SERIAL_BAUD=115200

# ---------------------------------------------------------------------------
# Camera  (IMX708 — Arducam 12MP / Pi Camera Module 3 with autofocus)
# ---------------------------------------------------------------------------
# CAMERA_WIDTH=1280
# CAMERA_HEIGHT=720
# CAMERA_FPS=30
# CAMERA_ROTATION=0              # 0=none  1=90°CW  2=180°  3=90°CCW

# Image quality
# CAMERA_SHARPNESS=1.5           # 0–16   (default 1.0)
# CAMERA_CONTRAST=1.1            # 0–32   (default 1.0)
# CAMERA_NOISE_REDUCTION=1       # 0=off  1=fast  2=high-quality
# CAMERA_AWB_MODE=0              # 0=auto 1=incandescent 2=tungsten 3=fluorescent
#                                #        4=indoor 5=daylight 6=cloudy
# CAMERA_AE_METERING_MODE=0      # 0=centre-weighted  1=spot  2=matrix

# Autofocus (IMX708)
# CAMERA_AF_MODE=2               # 0=manual  1=auto (trigger)  2=continuous
# CAMERA_AF_SPEED=1              # 0=normal  1=fast
# CAMERA_AF_RANGE=0              # 0=normal (0.1m–inf)  1=macro  2=full

# ---------------------------------------------------------------------------
# Stream
# ---------------------------------------------------------------------------
# MJPEG_QUALITY=75               # JPEG quality 1–95

# ---------------------------------------------------------------------------
# Face detection  (MediaPipe)
# ---------------------------------------------------------------------------
# FACE_MIN_CONFIDENCE=0.4        # Lower = detects more faces, more false positives
# FACE_MODEL_SELECTION=1         # 0=short range (<2 m)  1=full range (room scale)

# ---------------------------------------------------------------------------
# Object detection  (MediaPipe EfficientDet-Lite0 TFLite — run download_model.py first)
# ---------------------------------------------------------------------------
# YOLO_CONFIDENCE=0.45

# Detection performance (reduce CPU load on Pi 4)
# DET_SCALE=0.5    # Detect at half resolution; boxes are scaled back automatically (0.25–1.0)
# DET_SKIP=2       # Only run detector every N frames; reuse boxes in between (1=every frame)

# ---------------------------------------------------------------------------
# Control
# ---------------------------------------------------------------------------
# PAN_INVERT=false               # Flip pan direction without rewiring
# TILT_INVERT=false              # Flip tilt direction without rewiring
# MAX_SPEED_DEG_S=45.0            # Web UI speed slider default / motion cap (deg/s)

# ---------------------------------------------------------------------------
# IMU / Compass orientation alignment
# ---------------------------------------------------------------------------
# IMU_ROLL_SIGN=1                # Flip roll axis:  1=normal  -1=invert
# IMU_PITCH_SIGN=1               # Flip pitch axis: 1=normal  -1=invert
# IMU_SWAP_ROLL_PITCH=false      # Swap roll and pitch (sensor mounted 90° rotated)
# IMU_ROLL_OFFSET_DEG=0.0       # Zero-point offset applied after sign/swap correction
# IMU_PITCH_OFFSET_DEG=0.0      #   e.g. if pitch reads +90° when level: set -90
# MAG_HDG_OFFSET_DEG=0.0        # Add fixed offset to compass heading (degrees)
#                                #   Use for magnetic declination or physical mount offset
#                                #   Example: -14.0 for ~14°W declination in Pacific NW
# MAG_HDG_INVERT=false           # Flip compass direction (sensor mounted backwards)
# MAG_TILT_COMPENSATE=true       # Set false if compass is on pan axis (doesn't tilt with camera)

# ---------------------------------------------------------------------------
# Tracking PID
# ---------------------------------------------------------------------------
# PID_MAX_VEL_DEG_S=45.0         # Max tracking velocity cap (deg/s)

# ---------------------------------------------------------------------------
# Motion (ESP32)
# ---------------------------------------------------------------------------
# ACCEL_DEG_S2=120.0             # Stepper acceleration (deg/s²)

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# FACE_RECOGNITION_TOLERANCE=0.5 # Lower = stricter match  (0.4–0.6 typical)
# ANTHROPIC_API_KEY=sk-ant-...   # Claude API — optional NL command features
