# Copy to .env and edit — loaded by config.py at startup.
# All values have sensible defaults; only override what you need.
# cp .env.example .env

# ---------------------------------------------------------------------------
# Serial
# ---------------------------------------------------------------------------
# SERIAL_PORT=/dev/serial0       # GPIO UART (hardware); use /dev/ttyUSB0 for USB
# SERIAL_BAUD=115200

# ---------------------------------------------------------------------------
# Camera  (IMX219 NoIR — Pi Camera V2)
# ---------------------------------------------------------------------------
# CAMERA_WIDTH=1280
# CAMERA_HEIGHT=720
# CAMERA_FPS=30
# CAMERA_ROTATION=2              # 0=none  1=90°CW  2=180°  3=90°CCW

# Image quality — tuned for face detection on NoIR sensor
# CAMERA_SHARPNESS=2.0           # 0–16   (default 1.0 — raise for crisper edges)
# CAMERA_CONTRAST=1.2            # 0–32   (default 1.0 — slight boost helps features)
# CAMERA_NOISE_REDUCTION=2       # 0=off  1=fast  2=high-quality
# CAMERA_AWB_MODE=0              # 0=auto 1=incandescent 2=tungsten 3=fluorescent
#                                #        4=indoor 5=daylight 6=cloudy
# CAMERA_AE_METERING_MODE=0      # 0=centre-weighted  1=spot  2=matrix

# ---------------------------------------------------------------------------
# Stream
# ---------------------------------------------------------------------------
# MJPEG_QUALITY=75               # JPEG quality 1–95

# ---------------------------------------------------------------------------
# Face detection  (MediaPipe)
# ---------------------------------------------------------------------------
# FACE_MIN_CONFIDENCE=0.4        # Lower = detects more faces, more false positives
# FACE_MODEL_SELECTION=1         # 0=short range (<2 m)  1=full range (room scale)

# ---------------------------------------------------------------------------
# Object detection  (MediaPipe EfficientDet-Lite0 TFLite — run download_model.py first)
# ---------------------------------------------------------------------------
# YOLO_CONFIDENCE=0.45

# Detection performance (reduce CPU load on Pi 4)
# DET_SCALE=0.5    # Detect at half resolution; boxes are scaled back automatically (0.25–1.0)
# DET_SKIP=2       # Only run detector every N frames; reuse boxes in between (1=every frame)

# ---------------------------------------------------------------------------
# Control
# ---------------------------------------------------------------------------
# PAN_INVERT=false               # Flip pan direction without rewiring
# TILT_INVERT=false              # Flip tilt direction without rewiring
# JOYSTICK_DEFAULT_SPEED=45.0    # Web UI speed slider default (deg/s)

# ---------------------------------------------------------------------------
# Tracking PID
# ---------------------------------------------------------------------------
# PID_MAX_VEL_DEG_S=45.0         # Max tracking velocity cap (deg/s)

# ---------------------------------------------------------------------------
# Motion (ESP32)
# ---------------------------------------------------------------------------
# ACCEL_DEG_S2=120.0             # Stepper acceleration (deg/s²)

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# FACE_RECOGNITION_TOLERANCE=0.5 # Lower = stricter match  (0.4–0.6 typical)
# ANTHROPIC_API_KEY=sk-ant-...   # Claude API — optional NL command features
